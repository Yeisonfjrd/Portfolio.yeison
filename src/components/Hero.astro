---
import Badge from "./Badge.astro";
import SocialPill from "./SocialPill.astro";
import LinkedInIcon from "./icons/LinkedIn.astro";
import GitHubIcon from "./icons/GitHub.astro";
import MailIcon from "./icons/Mail.astro";
import StatusTerminal from "./StatusTerminal.astro";
---

<div class="max-w-3xl mx-auto py-8">
  <div class="flex flex-col md:flex-row items-center md:items-start gap-10">

    <div class="flex-1 flex flex-col items-center md:items-start text-center md:text-left">
      <div class="mb-5">
        <Badge>
          <span class="flex items-center gap-2">
            <span class="relative flex w-3 h-3">
              <span class="absolute inline-flex w-full h-full bg-green-400 rounded-full opacity-75 animate-ping"></span>
              <span class="relative inline-flex w-3 h-3 bg-green-500 rounded-full"></span>
            </span>
            Disponible para trabajar
          </span>
        </Badge>
      </div>

      <h1 class="text-4xl md:text-5xl font-bold text-white mb-4 leading-tight">
        Yeison <span class="text-transparent bg-clip-text bg-gradient-to-r from-violet-400 to-indigo-400">Fajardo</span>
      </h1>

      <p class="text-lg text-slate-400 mb-8 leading-relaxed">
        Backend engineer. Construyo sistemas que duran:<br/>
        APIs, modelos de datos, tests, arquitectura.
      </p>

      <nav class="flex flex-wrap gap-3 justify-center md:justify-start mb-10">
        <SocialPill href="https://www.linkedin.com/in/yeison-fajardo">
          <LinkedInIcon class="size-5" />
          LinkedIn
        </SocialPill>
        <SocialPill href="https://github.com/Yeisonfjrd">
          <GitHubIcon class="size-5" />
          GitHub
        </SocialPill>
        <SocialPill href="mailto:andresfajardo1606@gmail.com">
          <MailIcon class="size-5" />
          andresfajardo1606@gmail.com
        </SocialPill>
      </nav>

      <StatusTerminal />
    </div>

    <div class="flex-shrink-0">
      <div class="relative">
        <div class="absolute -inset-4 rounded-full bg-violet-600/15 blur-2xl"></div>
        <div class="relative w-36 h-36 rounded-full overflow-hidden ring-2 ring-violet-500/30 shadow-xl">
          <img
            src="/Yeison-fajardo.webp"
            alt="Yeison Fajardo"
            class="object-cover w-full h-full"
            style="object-position: 50% 30%"
          />
        </div>
        <span class="absolute bottom-1 right-1 w-4 h-4 bg-green-400 border-2 border-[#0f0f1a] rounded-full"></span>
      </div>
    </div>

  </div>
</div>